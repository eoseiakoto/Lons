# Database — two-role connection model (S19-STAB-1 follow-up).
#
# `DATABASE_URL` is what every application service (graphql-server,
# rest-server, scheduler, …) connects with at runtime. It uses the
# `lons_app` role, which is NOT a table owner — so the RLS policies
# installed in migration 20260526100000 actually enforce against it.
# The application's RLS interceptor sets `app.current_tenant` and
# `app.is_platform_admin` session vars per request to satisfy them.
#
# `DIRECT_DATABASE_URL` is what `prisma migrate deploy`, `prisma db
# pull`, `prisma migrate resolve`, and the seed connect with. It uses
# the `lons` owner role, which bypasses RLS by default — necessary
# because seeding writes across every tenant. The seed.ts source
# explicitly constructs `new PrismaClient({ datasourceUrl: process
# .env.DIRECT_DATABASE_URL })` so it picks up the owner URL even
# though Prisma's runtime PrismaClient defaults to DATABASE_URL.
#
# The `lons_app` role is created by the migration on first
# `prisma migrate deploy`. Bootstrap order: docker compose up (creates
# `lons` only) → prisma migrate deploy (creates `lons_app` via the
# 20260526200000 migration) → application can now connect.
#
# For staging/prod: the `lons_app` password must come from a secret
# manager, not from `.env.example`. See Docs/MIGRATION-PLAYBOOK.md §6
# and §6.1 (lons_app provisioning).
DATABASE_URL=postgresql://lons_app:lons_app_dev_password@localhost:5432/lons
DIRECT_DATABASE_URL=postgresql://lons:lons_dev_password@localhost:5432/lons
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
# Security Hardening (SEC-9): when NODE_ENV=production the JwtService
# throws on boot if either key file is unreadable — ephemeral keys are
# not permitted in production. Generate a 2048-bit RSA pair with:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY=../../keys/private.pem
JWT_PUBLIC_KEY=../../keys/public.pem
JWT_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=604800

# Encryption
ENCRYPTION_KEY=base64-encoded-32-byte-key-here
ENCRYPTION_IV_LENGTH=16
# KEY_PROVIDER=env|vault|aws
KEY_PROVIDER=env

# Searchable-hash pepper (Security Hardening SEC-5).
#
# HMAC-SHA-256 key for the deterministic hash columns that index
# encrypted PII (email, phone, tax id, etc.). Without this, equality
# lookups against encrypted columns either silently miss (plain SHA-256
# would still work but be brute-forceable from a leaked DB) or fail
# closed (the application throws on first hash computation).
#
# Operational rules:
#   - MUST be at least 32 characters of entropy.
#   - Generate with:
#       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   - Store in a secret manager (Vault / AWS Secrets Manager) — never
#     commit a real value to the repo.
#   - Rotating this value invalidates ALL existing hashes. After
#     rotation, run `pnpm tsx scripts/backfill-pii-hashes-and-encrypt.ts`
#     to recompute every hash column.
HASH_PEPPER=

# Vault Key Provider (set KEY_PROVIDER=vault to enable)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/data/lons/encryption
VAULT_KEY_CACHE_TTL_MS=3600000

# AWS Secrets Manager Key Provider (set KEY_PROVIDER=aws to enable)
AWS_SM_SECRET_ID=lons/encryption-key
AWS_SM_REGION=eu-west-1
AWS_SM_CACHE_TTL_MS=3600000

# Services
SCORING_SERVICE_URL=http://localhost:8000
NOTIFICATION_SERVICE_URL=http://localhost:3003
INTEGRATION_SERVICE_URL=http://localhost:3004

# External (Phase 5)
MTN_MOMO_API_KEY=
MTN_MOMO_API_SECRET=
MTN_MOMO_ENVIRONMENT=sandbox
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=

# AML Screening
SCREENING_PROVIDER=mock
COMPLYADVANTAGE_API_KEY=
SCREENING_CACHE_TTL_HOURS=24
SCREENING_FUZZINESS=0.6

# Observability
LOG_LEVEL=debug
ENABLE_TRACING=false

# Server
PORT=3000
REST_PORT=3001

# CORS allowlist (P0-003) — explicit origins for cross-origin requests from
# the portals. Comma-separated extras can be provided via CORS_ORIGINS for
# preview/staging deploys. Defaults match the lons.sh port assignments
# (admin-portal=3100, platform-portal=3200). Earlier defaults of 3001/3002
# caused the platform-portal /system health card to mark the REST server
# as DOWN — see post-Sprint-18 stabilisation commit 525f4d7.
ADMIN_PORTAL_URL=http://localhost:3100
PLATFORM_PORTAL_URL=http://localhost:3200
CORS_ORIGINS=

# Audit log retention (months) — used by AuditPartitionManager
AUDIT_LOG_RETENTION_MONTHS=24
