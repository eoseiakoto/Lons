{
  "info": {
    "_postman_id": "lons-rest-collection",
    "name": "Lons - REST API",
    "description": "REST API collection for the Lons B2B2C lending platform. Includes webhook endpoints, health checks, and REST loan/repayment operations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "apiKey",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "x-api-key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{apiKey}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "description": "Health check endpoints",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{restUrl}}/health",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Basic health check endpoint. Returns service status."
          }
        }
      ]
    },
    {
      "name": "Loan Requests (REST)",
      "description": "REST endpoints for loan request operations",
      "item": [
        {
          "name": "Create Loan Request",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('idempotencyKey', require('uuid').v4());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              },
              {
                "key": "x-idempotency-key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"<customer-id>\",\n  \"productId\": \"<product-id>\",\n  \"requestedAmount\": \"5000.0000\",\n  \"requestedTenor\": 30,\n  \"currency\": \"GHS\",\n  \"channel\": \"api\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{restUrl}}/v1/loan-requests",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "v1",
                "loan-requests"
              ]
            },
            "description": "Create a new loan request via REST API. Generates an idempotency key automatically."
          }
        },
        {
          "name": "Get Loan Request",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{restUrl}}/v1/loan-requests/:id",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "v1",
                "loan-requests",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<loan-request-id>",
                  "description": "Loan request UUID"
                }
              ]
            },
            "description": "Get a loan request by ID."
          }
        },
        {
          "name": "Accept Loan Offer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{restUrl}}/v1/loan-requests/:id/accept",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "v1",
                "loan-requests",
                ":id",
                "accept"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "<loan-request-id>",
                  "description": "Loan request UUID"
                }
              ]
            },
            "description": "Accept a loan offer for a given loan request."
          }
        }
      ]
    },
    {
      "name": "Repayments (REST)",
      "description": "REST endpoints for repayment operations",
      "item": [
        {
          "name": "Create Repayment",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('idempotencyKey', require('uuid').v4());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              },
              {
                "key": "x-idempotency-key",
                "value": "{{idempotencyKey}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contractId\": \"<contract-id>\",\n  \"amount\": \"500.0000\",\n  \"currency\": \"GHS\",\n  \"method\": \"mobile_money\",\n  \"source\": \"MTN MoMo\",\n  \"externalRef\": \"TXN-12345\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{restUrl}}/v1/repayments",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "v1",
                "repayments"
              ]
            },
            "description": "Record a repayment. Generates an idempotency key automatically."
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "description": "Webhook callback endpoints for external service integrations",
      "item": [
        {
          "name": "Wallet Webhook Callback",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"txn-abc-123\",\n  \"status\": \"completed\",\n  \"amount\": \"5000.0000\",\n  \"currency\": \"GHS\",\n  \"timestamp\": \"2026-03-27T10:30:00.000Z\",\n  \"metadata\": {\n    \"contractId\": \"<contract-id>\",\n    \"type\": \"disbursement\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{restUrl}}/v1/webhooks/wallet",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "v1",
                "webhooks",
                "wallet"
              ]
            },
            "description": "Generic wallet provider webhook callback. Receives transaction status updates."
          }
        },
        {
          "name": "M-Pesa STK Push Callback",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Body\": {\n    \"stkCallback\": {\n      \"MerchantRequestID\": \"29115-34620561-1\",\n      \"CheckoutRequestID\": \"ws_CO_191220191020363925\",\n      \"ResultCode\": 0,\n      \"ResultDesc\": \"The service request is processed successfully.\",\n      \"CallbackMetadata\": {\n        \"Item\": [\n          { \"Name\": \"Amount\", \"Value\": 5000 },\n          { \"Name\": \"MpesaReceiptNumber\", \"Value\": \"NLJ7RT61SV\" },\n          { \"Name\": \"TransactionDate\", \"Value\": 20260327103000 },\n          { \"Name\": \"PhoneNumber\", \"Value\": 254708374149 }\n        ]\n      }\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{restUrl}}/v1/webhooks/mpesa/stk-callback",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "v1",
                "webhooks",
                "mpesa",
                "stk-callback"
              ]
            },
            "description": "M-Pesa STK Push callback. Receives payment confirmation from Safaricom."
          }
        },
        {
          "name": "M-Pesa B2C Result",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Result\": {\n    \"ResultType\": 0,\n    \"ResultCode\": 0,\n    \"ResultDesc\": \"The service request is processed successfully.\",\n    \"OriginatorConversationID\": \"10571-7910404-1\",\n    \"ConversationID\": \"AG_20260327_00004e48cf7e3533f581\",\n    \"TransactionID\": \"NLJ41HAY6Q\",\n    \"ResultParameters\": {\n      \"ResultParameter\": [\n        { \"Key\": \"TransactionAmount\", \"Value\": 5000 },\n        { \"Key\": \"TransactionReceipt\", \"Value\": \"NLJ41HAY6Q\" },\n        { \"Key\": \"ReceiverPartyPublicName\", \"Value\": \"254708374149 - John Doe\" },\n        { \"Key\": \"TransactionCompletedDateTime\", \"Value\": \"27.03.2026 10:30:00\" }\n      ]\n    }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{restUrl}}/v1/webhooks/mpesa/b2c-result",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "v1",
                "webhooks",
                "mpesa",
                "b2c-result"
              ]
            },
            "description": "M-Pesa B2C (Business to Customer) result callback. Receives disbursement confirmation from Safaricom."
          }
        },
        {
          "name": "Africa's Talking Delivery Report",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"ATXid_123456789\",\n  \"status\": \"Success\",\n  \"phoneNumber\": \"+233241234567\",\n  \"networkCode\": \"62001\",\n  \"failureReason\": \"\",\n  \"retryCount\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{restUrl}}/v1/webhooks/africas-talking/dlr",
              "host": [
                "{{restUrl}}"
              ],
              "path": [
                "v1",
                "webhooks",
                "africas-talking",
                "dlr"
              ]
            },
            "description": "Africa's Talking SMS delivery report callback. Receives delivery status for sent SMS notifications."
          }
        }
      ]
    }
  ]
}