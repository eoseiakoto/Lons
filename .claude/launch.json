  "configurations": [
    {
      "name": "graphql-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["pnpm@9", "--filter", "@lons/graphql-server", "dev"],
      "port": 3000
    },
    {
      "name": "rest-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["pnpm@9", "--filter", "@lons/rest-server", "dev"],
      "port": 3002
    },
    {
      "name": "admin-portal",
      "runtimeExecutable": "npx",
