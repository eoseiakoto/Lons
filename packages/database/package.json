{
  "name": "@lons/database",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm db:generate && tsc",
    "clean": "rm -rf dist",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "db:seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@lons/shared-types": "workspace:*",
    "@lons/common": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@prisma/client": "^5.14.0",
    "argon2": "^0.40.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@lons/eslint-config": "workspace:*",
    "dotenv-cli": "^7.4.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
