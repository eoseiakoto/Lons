model WebhookEndpoint {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String              @map("tenant_id") @db.Uuid
  url           String              @db.VarChar(2048)
  events        String[]
  authMethod    WebhookAuthMethod   @default(hmac) @map("auth_method")
  secret        String              @db.Text
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?           @map("deleted_at") @db.Timestamptz(6)

  deliveryLogs  WebhookDeliveryLog[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("webhook_endpoints")
}

model WebhookDeliveryLog {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  webhookEndpointId   String                @map("webhook_endpoint_id") @db.Uuid
  event               String                @db.VarChar(100)
  payload             Json                  @db.JsonB
  httpStatus          Int?                  @map("http_status")
  responseBody        String?               @map("response_body") @db.Text
  retryCount          Int                   @default(0) @map("retry_count")
  status              WebhookDeliveryStatus @default(pending)
  nextRetryAt         DateTime?             @map("next_retry_at") @db.Timestamptz(6)
  deliveredAt         DateTime?             @map("delivered_at") @db.Timestamptz(6)
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  webhookEndpoint     WebhookEndpoint       @relation(fields: [webhookEndpointId], references: [id])

  @@index([webhookEndpointId])
  @@index([status])
  @@index([webhookEndpointId, status, createdAt])
  @@map("webhook_delivery_logs")
}

