  product      Product       @relation(fields: [productId], references: [id])
  loanRequests LoanRequest[]

  @@index([tenantId])
  @@index([customerId])
  @@index([createdAt])
  @@map("scoring_results")
}

model Contract {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String                 @map("tenant_id") @db.Uuid
  contractNumber       String                 @map("contract_number") @db.VarChar(50)
  customerId           String                 @map("customer_id") @db.Uuid
  productId            String                 @map("product_id") @db.Uuid
  productVersion       Int?                   @map("product_version")
  lenderId             String                 @map("lender_id") @db.Uuid
  loanRequestId        String                 @map("loan_request_id") @db.Uuid
  principalAmount      Decimal                @map("principal_amount") @db.Decimal(19, 4)
  interestRate         Decimal                @map("interest_rate") @db.Decimal(7, 4)
  interestAmount       Decimal?               @map("interest_amount") @db.Decimal(19, 4)
  totalFees            Decimal?               @map("total_fees") @db.Decimal(19, 4)
  totalCostCredit      Decimal?               @map("total_cost_credit") @db.Decimal(19, 4)
  currency             String                 @db.VarChar(3)
  tenorDays            Int?                   @map("tenor_days")
  repaymentMethod      RepaymentMethod        @map("repayment_method")
  startDate            DateTime               @map("start_date") @db.Date
  maturityDate         DateTime               @map("maturity_date") @db.Date
  firstPaymentDate     DateTime?              @map("first_payment_date") @db.Date
  outstandingPrincipal Decimal?               @map("outstanding_principal") @db.Decimal(19, 4)
  outstandingInterest  Decimal?               @map("outstanding_interest") @db.Decimal(19, 4)
  outstandingFees      Decimal?               @map("outstanding_fees") @db.Decimal(19, 4)
  outstandingPenalties Decimal?               @map("outstanding_penalties") @db.Decimal(19, 4)
  totalOutstanding     Decimal?               @map("total_outstanding") @db.Decimal(19, 4)
  totalPaid            Decimal?               @map("total_paid") @db.Decimal(19, 4)
  daysPastDue          Int                    @default(0) @map("days_past_due")
  status               ContractStatus         @default(active)
  classification       ContractClassification @default(performing)
  termsSnapshot        Json?                  @map("terms_snapshot")
  restructured         Boolean                @default(false)
  restructureCount     Int                    @default(0) @map("restructure_count")
  disbursementId       String?                @map("disbursement_id") @db.Uuid
  metadata             Json?
  settledAt            DateTime?              @map("settled_at") @db.Timestamptz(6)
  defaultedAt          DateTime?              @map("defaulted_at") @db.Timestamptz(6)
  writtenOffAt         DateTime?              @map("written_off_at") @db.Timestamptz(6)
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer           Customer                 @relation(fields: [customerId], references: [id])
  product            Product                  @relation(fields: [productId], references: [id])
  lender             Lender                   @relation(fields: [lenderId], references: [id])
  loanRequests       LoanRequest[]            @relation("RequestContract")
  repaymentSchedule  RepaymentScheduleEntry[]
  disbursements      Disbursement[]
  repayments         Repayment[]
  ledgerEntries      LedgerEntry[]
  notifications      Notification[]
