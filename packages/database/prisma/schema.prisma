// ============================================================================
// PLATFORM SCHEMA
// ============================================================================

model Tenant {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String       @db.VarChar(255)
  slug               String       @unique @db.VarChar(63)
  legalName          String?      @map("legal_name") @db.VarChar(255)
  registrationNumber String?      @map("registration_number") @db.VarChar(100)
  country            String       @db.VarChar(3)
  schemaName         String       @unique @map("schema_name") @db.VarChar(63)
  planTier           PlanTier     @default(starter) @map("plan_tier")
  status             TenantStatus @default(provisioning)
  platformFeePercent Decimal?     @map("platform_fee_percent") @db.Decimal(5, 2)
  settings           Json?
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?    @map("deleted_at") @db.Timestamptz(6)

  walletProviderConfigs       WalletProviderConfig[]
  notificationProviderConfigs NotificationProviderConfig[]
  notificationMockLogs        NotificationMockLog[]
  feedbacks                   Feedback[]
  surveyResponses             SurveyResponse[]
  // Sprint 14 (S14-9, S14-12): commercial billing relations.
  billingConfig               TenantBillingConfig?
  billingInvoices             BillingInvoice[]

  @@map("tenants")
}

/// Sprint 14 (S14-9) — DB-driven plan tier definition.
///
/// One row per tier (starter / growth / enterprise). Stores the complete
/// capability set: allowed product types, operational limits, feature
/// flags, API access, branding. Platform admins edit these rows via
/// `updatePlanTierConfig` — changing tier capabilities does NOT require a
/// code deploy. The PlanTierConfigService caches each row in Redis with
/// a 5-minute TTL and invalidates on update.
///
/// Limits use `Int?` / `Decimal?` with `null` meaning "unlimited"
/// (enterprise tier).
model PlanTierConfig {
  id                                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tier                              PlanTier @unique
  displayName                       String   @map("display_name") @db.VarChar(50)

  /// JSONB array of `ProductType` strings (e.g. ["micro_loan"] for
  /// starter, ["micro_loan","overdraft","bnpl","invoice_financing"] for
  /// enterprise). Validated at the service layer against the
  /// `ProductType` enum to prevent typo'd entries from going live.
  allowedProductTypes               Json     @map("allowed_product_types")

  // §3.2 Operational limits. null = unlimited (enterprise behaviour).
  maxActiveProducts                 Int?     @map("max_active_products")
  maxCustomers                      Int?     @map("max_customers")
  maxMonthlyDisbursementVolumeUsd   Decimal? @map("max_monthly_disbursement_volume_usd") @db.Decimal(19, 4)
  maxMonthlyTransactions            Int?     @map("max_monthly_transactions")
  maxLenderConfigs                  Int?     @map("max_lender_configs")
  maxBnplMerchants                  Int?     @map("max_bnpl_merchants")
  maxPortalUsers                    Int?     @map("max_portal_users")
  dataRetentionMonths               Int      @default(12) @map("data_retention_months")

  /// JSONB feature-flag bag. Shape (see SPEC-plan-tiers.md §3.3):
  /// {
  ///   "mlScoring": boolean,
  ///   "aiRecovery": boolean,
  ///   "collectionsLevel": "basic" | "full" | "full_with_agency",
  ///   "customReports": boolean,
  ///   "scheduledReports": boolean,
  ///   "settlementLevel": "basic" | "multi_party" | "multi_party_custom",
  ///   "reconciliationLevel": "daily_batch" | "daily_plus_ondemand" | "realtime_plus_daily",
  ///   "notificationChannels": string[],
  ///   "maxWebhookEndpoints": number | null,
  ///   "auditLogRetentionDays": number
  /// }
  featureFlags                      Json     @map("feature_flags")

  apiRateLimitPerMinute             Int      @default(60) @map("api_rate_limit_per_minute")
  restApiEnabled                    Boolean  @default(false) @map("rest_api_enabled")
  websocketEnabled                  Boolean  @default(false) @map("websocket_enabled")
  bulkOperationsEnabled             Boolean  @default(false) @map("bulk_operations_enabled")
  maxApiKeys                        Int?     @map("max_api_keys")

  /// JSONB branding options (see SPEC-plan-tiers.md §3.6):
  /// {
  ///   "fullBrandPalette": boolean,
  ///   "customEmailTemplates": boolean,
  ///   "customSmsSenderId": boolean,
  ///   "whiteLabel": boolean,
  ///   "customDomain": boolean
  /// }
  brandingOptions                   Json     @map("branding_options")

  createdAt                         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("plan_tier_configs")
}

/// Sprint 14 (S14-9) — per-tenant commercial billing configuration.
///
/// One row per tenant. Stores the SP's contracted rates: subscription
/// amount, per-disbursement basis-points rate, product-specific rate
/// modifiers (e.g. BNPL gets -10 bps vs base), volume-discount brackets,
/// and contract dates. Currency is USD by default; per-tenant other
/// currencies are supported (see `billingCurrency`).
model TenantBillingConfig {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String       @unique @map("tenant_id") @db.Uuid
  planTier                PlanTier     @map("plan_tier")
  subscriptionAmountUsd   Decimal      @map("subscription_amount_usd") @db.Decimal(19, 4)
  billingModel            BillingModel @default(per_disbursement) @map("billing_model")
  perDisbursementBps      Decimal?     @map("per_disbursement_bps") @db.Decimal(7, 2)
  revenueSharePct         Decimal?     @map("revenue_share_pct") @db.Decimal(5, 4)

  // §4.2 — per-product rate adjustments (basis points). Negative values
  // are discounts vs the base rate.
  microLoanRateModifier   Decimal      @default(0)   @map("micro_loan_rate_modifier") @db.Decimal(7, 2)
  overdraftRateModifier   Decimal      @default(0)   @map("overdraft_rate_modifier") @db.Decimal(7, 2)
  bnplRateModifier        Decimal      @default(-10) @map("bnpl_rate_modifier") @db.Decimal(7, 2)
  factoringRateModifier   Decimal      @default(-20) @map("factoring_rate_modifier") @db.Decimal(7, 2)

  /// §4.3 Volume discount brackets — JSONB array of
  /// `{ threshold: number; multiplier: string }`. Sorted descending by
  /// threshold at lookup time. Default empty (no volume discount).
  volumeDiscountTiers     Json         @default("[]") @map("volume_discount_tiers")

  billingCurrency         String       @default("USD") @map("billing_currency") @db.VarChar(3)
  paymentTermsDays        Int          @default(15)   @map("payment_terms_days")
  contractStartDate       DateTime     @map("contract_start_date") @db.Date
  contractEndDate         DateTime?    @map("contract_end_date") @db.Date

  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                  Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([planTier])
  @@map("tenant_billing_configs")
}

model PlatformUser {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// FIX-S13B-1 (F-S13B-1): `@unique` removed — the column is encrypted, so
  /// the constraint never fires (random IV ⇒ ciphertext differs per write).
  /// Uniqueness is now enforced on `emailHash` below.
  email            String           @db.VarChar(255)
  /// Sprint 13B (S13B-2): SHA-256 of normalised lowercase email for login lookups.
  /// Required because `email` is encrypted at rest (see ENCRYPTED_FIELDS).
  emailHash        String?          @map("email_hash") @db.VarChar(64)
  passwordHash     String           @map("password_hash") @db.VarChar(255)
  name             String?          @db.VarChar(255)
  role             PlatformUserRole
  mfaSecret        String?          @map("mfa_secret") @db.VarChar(255)
  mfaEnabled       Boolean          @default(false) @map("mfa_enabled")
  /// Sprint 15 (S15-6): JSON-encoded array of unused backup codes,
  /// AES-256-GCM encrypted at rest. Each code is consumed once on use.
  mfaBackupCodes   String?          @map("mfa_backup_codes") @db.Text
  lastLoginAt      DateTime?        @map("last_login_at") @db.Timestamptz(6)
  lockedUntil      DateTime?        @map("locked_until") @db.Timestamptz(6)
  failedLoginCount Int              @default(0) @map("failed_login_count")
  status           UserStatus       @default(active)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(6)

  /// FIX-S13B-1: dedupe enforced on the hash column. NULL hashes (pre-backfill)
  /// are treated as distinct by Postgres, which is the intended behaviour.
  @@unique([emailHash])
  @@map("platform_users")
}

// ============================================================================
// TENANT SCHEMA — CORE ENTITIES
// ============================================================================

model User {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String     @map("tenant_id") @db.Uuid
  email            String     @db.VarChar(255)
  /// Sprint 13B (S13B-2): SHA-256 of normalised lowercase email — drives
  /// tenant-scoped login lookups now that `email` is encrypted at rest.
  emailHash        String?    @map("email_hash") @db.VarChar(64)
  passwordHash     String     @map("password_hash") @db.VarChar(255)
  name             String?    @db.VarChar(255)
  phone            String?    @db.VarChar(20)
  roleId           String     @map("role_id") @db.Uuid
  mfaSecret        String?    @map("mfa_secret") @db.VarChar(255)
  mfaEnabled       Boolean    @default(false) @map("mfa_enabled")
  /// Sprint 15 (S15-6): JSON-encoded array of unused backup codes,
  /// AES-256-GCM encrypted at rest. Each code is consumed once on use.
  mfaBackupCodes   String?    @map("mfa_backup_codes") @db.Text
  lastLoginAt      DateTime?  @map("last_login_at") @db.Timestamptz(6)
  lockedUntil      DateTime?  @map("locked_until") @db.Timestamptz(6)
  failedLoginCount Int        @default(0) @map("failed_login_count")
  status           UserStatus @default(active)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?  @map("deleted_at") @db.Timestamptz(6)

  role              Role             @relation(fields: [roleId], references: [id])
  createdProducts   Product[]        @relation("ProductCreatedBy")
  productVersions   ProductVersion[] @relation("VersionCreatedBy")
  processedRequests LoanRequest[]    @relation("RequestProcessedBy")
  feedbacks         Feedback[]
  surveyResponses   SurveyResponse[]

  /// FIX-S13B-1 (F-S13B-1): the original `@@unique([tenantId, email])` is
  /// removed — encrypted columns can't enforce uniqueness. The unique
  /// constraint moves to the hash column (which also creates the implicit
  /// index that the prior `@@index([tenantId, emailHash])` provided).
  @@unique([tenantId, emailHash])
  @@index([tenantId])
  @@index([roleId])
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  permissions Json     @default("[]")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Lender {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String       @map("tenant_id") @db.Uuid
  name              String       @db.VarChar(255)
  licenseNumber     String?      @map("license_number") @db.VarChar(100)
  country           String?      @db.VarChar(3)
  fundingCapacity   Decimal?     @map("funding_capacity") @db.Decimal(19, 4)
  fundingCurrency   String?      @map("funding_currency") @db.VarChar(3)
  minInterestRate   Decimal?     @map("min_interest_rate") @db.Decimal(7, 4)
  maxInterestRate   Decimal?     @map("max_interest_rate") @db.Decimal(7, 4)
  settlementAccount Json?        @map("settlement_account")
  riskParameters    Json?        @map("risk_parameters")
  status            LenderStatus @default(active)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?    @map("deleted_at") @db.Timestamptz(6)

  products         Product[]
  contracts        Contract[]
  creditLines      CreditLine[]
  bnplTransactions BnplTransaction[]

  @@index([tenantId])
  @@map("lenders")
}

model Customer {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  externalId        String         @map("external_id") @db.VarChar(255)
  externalSource    String?        @map("external_source") @db.VarChar(100)
  fullName          String?        @map("full_name") @db.VarChar(255)
  dateOfBirth       DateTime?      @map("date_of_birth") @db.Date
  gender            Gender?
  nationalId        String?        @map("national_id") @db.VarChar(255)
  /// Security Hardening (SEC-1): HMAC-SHA-256 of normalised lowercase
  /// nationalId for indexed equality lookup. The plaintext is encrypted at
  /// rest, so direct lookups are impossible.
  nationalIdHash    String?        @map("national_id_hash") @db.VarChar(64)
  nationalIdType    String?        @map("national_id_type") @db.VarChar(50)
  phonePrimary      String?        @map("phone_primary") @db.VarChar(50)
  /// Security Hardening (SEC-1): HMAC-SHA-256 of normalised lowercase
  /// phonePrimary. Drives admin portal "find customer by phone" lookups.
  phonePrimaryHash  String?        @map("phone_primary_hash") @db.VarChar(64)
  phoneSecondary    String?        @map("phone_secondary") @db.VarChar(50)
  email             String?        @db.VarChar(255)
  /// Security Hardening (SEC-1): HMAC-SHA-256 of normalised lowercase email.
  emailHash         String?        @map("email_hash") @db.VarChar(64)
  country           String?        @db.VarChar(3)
  region            String?        @db.VarChar(100)
  city              String?        @db.VarChar(100)
  kycLevel          KycLevel       @default(none) @map("kyc_level")
  kycVerifiedAt     DateTime?      @map("kyc_verified_at") @db.Timestamptz(6)
  segment           String?        @db.VarChar(100)
  status            CustomerStatus @default(active)
  blacklistReason   String?        @map("blacklist_reason") @db.Text
  watchlist         Boolean        @default(false)
  metadata          Json?
  anonymizedAt      DateTime?      @map("anonymized_at") @db.Timestamptz(6)
  anonymizedBy      String?        @map("anonymized_by") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?      @map("deleted_at") @db.Timestamptz(6)

  consents         CustomerConsent[]
  subscriptions    Subscription[]
  loanRequests     LoanRequest[]
  scoringResults   ScoringResult[]
  contracts        Contract[]
  disbursements    Disbursement[]
  repayments       Repayment[]
  notifications    Notification[]
  screeningResults ScreeningResult[]
  creditLines      CreditLine[]
  walletMappings   WalletAccountMapping[]
  bnplTransactions BnplTransaction[]
  invoices         Invoice[]
  bnplCreditLines  BnplCreditLine[]
  microLoanCreditLimitChanges MicroLoanCreditLimitChange[]

  @@unique([tenantId, externalId, externalSource])
  @@index([tenantId])
  /// Security Hardening (SEC-4): the legacy `@@index([phonePrimary])` and
  /// `@@index([nationalId])` indexed AES-GCM ciphertext (random IV per
  /// write) — every write produces a different value, so the index is
  /// pure storage/IO waste. Replaced by hash-column indexes below.
  @@index([tenantId, phonePrimaryHash])
  @@index([tenantId, nationalIdHash])
  @@index([tenantId, emailHash])
  @@index([status])
  @@index([segment])
  @@map("customers")
}

/// Sprint 11 A10 — indexed lookup table for wallet → customer routing.
/// Replaces the previous full-scan over `customer.metadata.walletId`. The
/// wallet-webhook controller resolves an inbound (provider, walletId) to
/// (tenantId, customerId) via a unique index here, which is O(log n)
/// instead of O(n) and respects RLS once the tenant is known.
model WalletAccountMapping {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  walletId   String   @map("wallet_id") @db.VarChar(255)
  provider   String   @db.VarChar(50)
  isPrimary  Boolean  @default(true) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([provider, walletId])
  @@index([tenantId])
  @@index([customerId])
  @@map("wallet_account_mappings")
}

model CustomerConsent {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  customerId  String      @map("customer_id") @db.Uuid
  consentType ConsentType @map("consent_type")
  granted     Boolean
  grantedAt   DateTime?   @map("granted_at") @db.Timestamptz(6)
  revokedAt   DateTime?   @map("revoked_at") @db.Timestamptz(6)
  channel     String?     @db.VarChar(50)
  version     Int         @default(1)
  ipAddress   String?     @map("ip_address") @db.VarChar(45)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([customerId, consentType])
  @@map("customer_consents")
}

model ScreeningResult {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String             @map("tenant_id") @db.Uuid
  customerId     String             @map("customer_id") @db.Uuid
  externalId     String?            @map("external_id") @db.VarChar(255)
  provider       String             @db.VarChar(50)
  status         ScreeningStatus    @default(CLEAR)
  riskLevel      ScreeningRiskLevel @default(LOW) @map("risk_level")
  matchCount     Int                @default(0) @map("match_count")
  matchDetails   Json?              @map("match_details")
  rawResponse    Bytes?             @map("raw_response")
  screenedAt     DateTime           @default(now()) @map("screened_at") @db.Timestamptz(6)
  expiresAt      DateTime           @map("expires_at") @db.Timestamptz(6)
