// ============================================================================
// REFRESH TOKENS & API KEYS — auth infrastructure
//
// Tables created by 20260326221923_add_refresh_tokens_and_api_keys but missing
// from this schema until P1-004 (Sprint 10A) aligned them. Adding these models
// here is a no-op for existing databases; future migrations will track changes.
// ============================================================================

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.Char(64)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ApiKey {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  name               String    @db.VarChar(255)
  keyHash            String    @map("key_hash") @db.Char(64)
  /// Security Hardening (SEC-3): SHA-256 hash of the per-key secret.
  /// `apiKeyService.validateApiKey()` requires both `keyHash` and
  /// `secretHash` to match — closing the "secret never validated" loophole
  /// where the X-API-Secret header was extracted but never compared.
  /// VARCHAR(64) (not CHAR) so the existing pre-secret rows (created
  /// before this column was introduced) can carry an empty placeholder
  /// until they're rotated. Non-null with default '' so the migration is
  /// backwards-compatible — see migration
  /// 20260510100001_add_api_key_secret_hash for the rotation policy.
  secretHash         String    @default("") @map("secret_hash") @db.VarChar(64)
  rateLimitPerMinute Int       @default(60) @map("rate_limit_per_minute")
  expiresAt          DateTime? @map("expires_at") @db.Timestamptz(6)
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt         DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([keyHash])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([revokedAt])
  @@index([expiresAt])
  @@map("api_keys")
}

// ============================================================================
// OVERDRAFT — credit lines, drawdowns, limit changes (Sprint 10B)
//
// One CreditLine per (tenant, customer, overdraft product). Drawdowns are
// individual overdraft transactions; CreditLimitChange is an immutable audit
// record of every limit adjustment (matched to FR-OD-003.6).
//
// All monetary fields are Decimal(19,4). Per CLAUDE.md, money flows as
// strings through every service boundary — no Number() coercion. The RLS
// migration in 20260501100000_add_overdraft_models attaches tenant_isolation
// policies to all three tables.
// ============================================================================

model CreditLine {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  customerId        String           @map("customer_id") @db.Uuid
  productId         String           @map("product_id") @db.Uuid
  lenderId          String           @map("lender_id") @db.Uuid
  currency          String           @db.VarChar(3)
  approvedLimit     Decimal          @map("approved_limit") @db.Decimal(19, 4)
  availableBalance  Decimal          @map("available_balance") @db.Decimal(19, 4)
  outstandingAmount Decimal          @default(0) @map("outstanding_amount") @db.Decimal(19, 4)
  interestRate      Decimal          @map("interest_rate") @db.Decimal(7, 4)
  interestAccrued   Decimal          @default(0) @map("interest_accrued") @db.Decimal(19, 4)
  feesOutstanding   Decimal          @default(0) @map("fees_outstanding") @db.Decimal(19, 4)
  penaltiesAccrued  Decimal          @default(0) @map("penalties_accrued") @db.Decimal(19, 4)
  status            CreditLineStatus @default(pending_activation)
  billingCycleDay   Int              @default(1) @map("billing_cycle_day")
  currentCycleStart DateTime?        @map("current_cycle_start") @db.Date
  currentCycleEnd   DateTime?        @map("current_cycle_end") @db.Date
  /// SPEC §8.2 / §9.1 — when the current cycle's crystallized balance is
  /// payable. Computed as `currentCycleEnd + product.gracePeriodDays`. Null
  /// until the first cycle close. Drives DPD / aging classification (A5).
  dueDate           DateTime?        @map("due_date") @db.Date
  /// Sprint 11 A5 — DPD/aging snapshot, refreshed daily by the aging job.
  /// `daysPastDue` is computed from `dueDate` and `today`; `agingBucket`
  /// is one of "current", "watch", "substandard", "doubtful", "loss".
  daysPastDue       Int              @default(0) @map("days_past_due")
  agingBucket       String?          @map("aging_bucket") @db.VarChar(20)
  agingUpdatedAt    DateTime?        @map("aging_updated_at") @db.Timestamptz(6)
  lastDrawdownAt    DateTime?        @map("last_drawdown_at") @db.Timestamptz(6)
  lastRepaymentAt   DateTime?        @map("last_repayment_at") @db.Timestamptz(6)
  lastLimitReviewAt DateTime?        @map("last_limit_review_at") @db.Timestamptz(6)
  activatedAt       DateTime?        @map("activated_at") @db.Timestamptz(6)
  expiresAt         DateTime?        @map("expires_at") @db.Timestamptz(6)
  frozenAt          DateTime?        @map("frozen_at") @db.Timestamptz(6)
  frozenReason      String?          @map("frozen_reason") @db.Text
  closedAt          DateTime?        @map("closed_at") @db.Timestamptz(6)
  closedReason      String?          @map("closed_reason") @db.Text
  metadata          Json?
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer              Customer              @relation(fields: [customerId], references: [id])
  product               Product               @relation(fields: [productId], references: [id])
  lender                Lender                @relation(fields: [lenderId], references: [id])
  drawdowns             Drawdown[]
  limitChanges          CreditLimitChange[]
  billingCycleHistories BillingCycleHistory[]

  @@unique([tenantId, customerId, productId])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([expiresAt])
  @@index([dueDate])
  @@index([agingBucket])
  @@map("credit_lines")
}

/// Frozen snapshot of one billing cycle on a credit line. Generated at
/// cycle close (`InterestService.closeCyclesDue`). Each row records the
/// cycle's opening / closing balance plus the interest, fees, and
/// penalties that crystallized during the cycle. Powers statement
/// regeneration (A6) and the DPD aging classification (A5) without
/// recomputing from the ledger.
///
/// Append-only: rows are never updated or deleted. The `paidInFull` flag
/// is set the first time a cycle's closing obligation reaches zero.
model BillingCycleHistory {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  creditLineId     String   @map("credit_line_id") @db.Uuid
  cycleNumber      Int      @map("cycle_number")
  cycleStart       DateTime @map("cycle_start") @db.Date
  cycleEnd         DateTime @map("cycle_end") @db.Date
  dueDate          DateTime @map("due_date") @db.Date
  openingBalance   Decimal  @map("opening_balance") @db.Decimal(19, 4)
  closingBalance   Decimal  @map("closing_balance") @db.Decimal(19, 4)
  interestCharged  Decimal  @map("interest_charged") @db.Decimal(19, 4)
  feesCharged      Decimal  @map("fees_charged") @db.Decimal(19, 4)
  penaltiesCharged Decimal  @map("penalties_charged") @db.Decimal(19, 4)
  totalRepayments  Decimal  @default(0) @map("total_repayments") @db.Decimal(19, 4)
  paidInFull       Boolean  @default(false) @map("paid_in_full")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  creditLine CreditLine @relation(fields: [creditLineId], references: [id])

  @@unique([creditLineId, cycleNumber])
  @@index([tenantId])
  @@index([creditLineId])
  @@index([dueDate])
  @@map("billing_cycle_histories")
}

enum CreditLineStatus {
  pending_activation
  active
  frozen
  suspended
  closed
  expired

  @@map("credit_line_status")
}

model Drawdown {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  creditLineId   String         @map("credit_line_id") @db.Uuid
  amount         Decimal        @db.Decimal(19, 4)
  currency       String         @db.VarChar(3)
  walletBalance  Decimal        @map("wallet_balance") @db.Decimal(19, 4)
  transactionRef String         @map("transaction_ref") @db.VarChar(255)
  walletRef      String?        @map("wallet_ref") @db.VarChar(255)
  feeAmount      Decimal        @default(0) @map("fee_amount") @db.Decimal(19, 4)
  status         DrawdownStatus @default(initiated)
  failureReason  String?        @map("failure_reason") @db.Text
  completedAt    DateTime?      @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  creditLine CreditLine @relation(fields: [creditLineId], references: [id])

  @@index([tenantId])
  @@index([creditLineId])
  @@index([transactionRef])
  @@index([status])
  @@map("drawdowns")
}

enum DrawdownStatus {
  initiated
  completed
  failed
  reversed

  @@map("drawdown_status")
}

model CreditLimitChange {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  creditLineId  String   @map("credit_line_id") @db.Uuid
  previousLimit Decimal  @map("previous_limit") @db.Decimal(19, 4)
  newLimit      Decimal  @map("new_limit") @db.Decimal(19, 4)
  reasonCode    String   @map("reason_code") @db.VarChar(50)
  reasonDetail  String?  @map("reason_detail") @db.Text
  triggeredBy   String   @map("triggered_by") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  creditLine CreditLine @relation(fields: [creditLineId], references: [id])

  @@index([tenantId])
  @@index([creditLineId])
  @@map("credit_limit_changes")
}

// ─────────────────────────────────────────────────────────────────────────
// Sprint 16 (S16-6) — Micro-Loan credit limit audit trail.
//
// Append-only audit row written every time a micro-loan subscription's
// credit limit changes. The existing `CreditLimitChange` model is for
// overdraft credit lines (FK to CreditLine); micro-loan limits live on
// `Subscription.creditLimit` and have their own audit table here.
//
// No `updated_at` or `deleted_at` — append-only by design.
// ─────────────────────────────────────────────────────────────────────────
model MicroLoanCreditLimitChange {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  customerId      String   @map("customer_id") @db.Uuid
  subscriptionId  String   @map("subscription_id") @db.Uuid
  previousLimit   Decimal  @map("previous_limit") @db.Decimal(19, 4)
  newLimit        Decimal  @map("new_limit") @db.Decimal(19, 4)
  /// `increase`, `decrease`, `suspension`, `restoration`.
  changeType      String   @map("change_type") @db.VarChar(20)
  reason          String   @db.Text
  /// `system` or `manual:<userId>` — mirrors BnplCreditLineAdjustment.
  triggeredBy     String   @map("triggered_by") @db.VarChar(80)
  /// Sprint 16 fixes (FIX-1): the identifier that triggered this row
  /// (e.g. a `repaymentId` for `reviewOnRepayment`, or a `contractId`
  /// for `reduceOnDefault`). Acts as an idempotency key — duplicate
  /// event deliveries that re-fire the same trigger are filtered out
  /// by the calling service before they re-apply the percentage math.
  /// Nullable for legacy rows + manual operator adjustments.
  sourceId        String?  @map("source_id") @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([subscriptionId])
  @@index([changeType])
  @@index([createdAt])
  /// FIX-1: scoped lookup for `(tenantId, sourceId)` — the dedupe
  /// query in `MicroLoanCreditLimitService.reviewOnRepayment`.
  @@index([tenantId, sourceId])
  @@map("micro_loan_credit_limit_changes")
}

// ─────────────────────────────────────────────────────────────────────────
// Sprint 16 (S16-11) — Configurable aging bucket thresholds + actions.
//
// Previously hardcoded as `DEFAULT_BUCKETS` in
// `services/process-engine/src/aging/aging.service.ts`. Now stored per
// tenant (optionally per product) so regulatory jurisdictions with
// different DPD thresholds can override.
//
// `actions` is JSON — see S16-12 for the action-matrix schema.
// ─────────────────────────────────────────────────────────────────────────
model AgingBucketConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  /// NULL = tenant-wide default. Product-specific config takes precedence.
  productId       String?  @map("product_id") @db.Uuid
  /// e.g., `current`, `watch`, `substandard`, `doubtful`, `default_61_90`, `loss`.
  bucketName      String   @map("bucket_name") @db.VarChar(50)
  daysMin         Int      @map("days_min")
  daysMax         Int      @map("days_max")
  /// Maps to `ContractStatus` enum (stringly so we can evolve without
  /// migrating every config row).
  contractStatus  String   @map("contract_status") @db.VarChar(30)
  /// Maps to `ContractClassification` enum.
  classification  String   @db.VarChar(30)
  sortOrder       Int      @map("sort_order")
  /// JSON array of `AgingAction` records (S16-12). See
  /// `services/process-engine/src/aging/aging-action.service.ts` for shape.
  actions         Json?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  product Product? @relation(fields: [productId], references: [id])

  @@unique([tenantId, productId, bucketName])
  @@index([tenantId])
  @@index([productId])
  @@map("aging_bucket_configs")
}

// ============================================================================
// SPRINT 11 — BNPL (Track B)
// ============================================================================
//
// Buy-Now-Pay-Later product type. Distinct from overdraft in that it is
// merchant-triggered (a customer's purchase at a merchant kicks off the
// origination flow) and broken into a fixed installment schedule. The
// merchant is settled either immediately (platform takes credit risk) or
// T+1 (batch settlement next business day) — see SettlementType.

/// SP-onboarded merchant. Owner of `tenantId` is the SP. One merchant
/// belongs to exactly one SP. Settlement type and discount rate are part
/// of the merchant's commercial agreement and govern how much of the
/// purchase amount the merchant receives at settlement.
model Merchant {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  name           String         @db.VarChar(255)
  code           String         @db.VarChar(50)
  status         MerchantStatus @default(pending)
  contactEmail   String?        @map("contact_email") @db.VarChar(255)
  contactPhone   String?        @map("contact_phone") @db.VarChar(50)
  settlementType SettlementType @default(T_PLUS_1) @map("settlement_type")
  /// Decimal fraction (e.g. 0.025 = 2.5%) of purchase amount the platform
  /// retains. Net merchant settlement = `purchaseAmount * (1 - discountRate)`.
  discountRate   Decimal        @map("discount_rate") @db.Decimal(7, 4)
  /// Merchant's wallet for settlement disbursement (provider-specific).
  walletId       String?        @map("wallet_id") @db.VarChar(255)
  walletProvider String?        @map("wallet_provider") @db.VarChar(50)
  metadata       Json?
  onboardedAt    DateTime?      @map("onboarded_at") @db.Timestamptz(6)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  transactions BnplTransaction[]
  settlements  MerchantSettlement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@map("merchants")
}

enum MerchantStatus {
  pending
  active
  suspended
  deactivated

  @@map("merchant_status")
}

enum SettlementType {
  IMMEDIATE
  T_PLUS_1

  @@map("settlement_type")
}

/// One BNPL purchase, parented by a merchant + customer + product. Lives
/// alongside the installment schedule that breaks `totalRepayable` into
/// fixed-amount due dates. Status traces the full purchase lifecycle.
model BnplTransaction {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String                @map("tenant_id") @db.Uuid
  customerId           String                @map("customer_id") @db.Uuid
  merchantId           String                @map("merchant_id") @db.Uuid
  productId            String                @map("product_id") @db.Uuid
  lenderId             String                @map("lender_id") @db.Uuid
  currency             String                @db.VarChar(3)
  /// What the customer bought, before any interest. Settlement is
  /// computed off this amount.
  purchaseAmount       Decimal               @map("purchase_amount") @db.Decimal(19, 4)
  /// What the customer ultimately repays — `purchaseAmount` plus interest.
  totalRepayable       Decimal               @map("total_repayable") @db.Decimal(19, 4)
  numberOfInstallments Int                   @map("number_of_installments")
  status               BnplTransactionStatus @default(initiated)
  /// Merchant's order identifier; unique per merchant.
  purchaseRef          String                @map("purchase_ref") @db.VarChar(255)
  merchantRef          String?               @map("merchant_ref") @db.VarChar(255)
  /// Decimal APR. `0` for the common interest-free promo case.
  interestRate         Decimal               @default(0) @map("interest_rate") @db.Decimal(7, 4)
  completedAt          DateTime?             @map("completed_at") @db.Timestamptz(6)
  cancelledAt          DateTime?             @map("cancelled_at") @db.Timestamptz(6)
  acceleratedAt        DateTime?             @map("accelerated_at") @db.Timestamptz(6)
  /// Idempotency key supplied by the merchant API call. Repeated calls
  /// with the same key short-circuit to the original result.
  idempotencyKey       String?               @map("idempotency_key") @db.VarChar(255)
  metadata             Json?
  /// FIX 5: settlementId links many transactions to one MerchantSettlement.
  /// IMMEDIATE settlements have one tx per row; T+1 batches share the
  /// same settlementId across all transactions covered by the batch.
  settlementId         String?               @map("settlement_id") @db.Uuid
  deletedAt            DateTime?             @map("deleted_at") @db.Timestamptz(6)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer     Customer              @relation(fields: [customerId], references: [id])
  merchant     Merchant              @relation(fields: [merchantId], references: [id])
  product      Product               @relation(fields: [productId], references: [id])
  installments InstallmentSchedule[]
  settlement   MerchantSettlement?   @relation(fields: [settlementId], references: [id])
  /// FIX 8: Lender FK relation (was missing — only had the scalar lenderId).
  lender       Lender                @relation(fields: [lenderId], references: [id])

  @@unique([tenantId, merchantId, purchaseRef])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([customerId])
  @@index([merchantId])
  @@index([lenderId])
  @@index([status])
  @@index([purchaseRef])
  @@index([settlementId])
  @@map("bnpl_transactions")
}

enum BnplTransactionStatus {
  initiated
  approved
  active
  completed
  cancelled
  accelerated
  defaulted
  refunded

  @@map("bnpl_transaction_status")
}

/// One row per installment on a BNPL transaction. `installmentNumber`
/// 1..N; due dates are derived from product config (first-installment
/// deferral + 30-day cadence by default). Status transitions:
///   pending → due (when `dueDate <= today`)
///   due → paid (full payment) | overdue (missed)
///   any → waived (operator action, e.g. partial refund offset)
model InstallmentSchedule {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  transactionId     String            @map("transaction_id") @db.Uuid
  installmentNumber Int               @map("installment_number")
  amount            Decimal           @db.Decimal(19, 4)
  principalPortion  Decimal           @map("principal_portion") @db.Decimal(19, 4)
  interestPortion   Decimal           @default(0) @map("interest_portion") @db.Decimal(19, 4)
  feePortion        Decimal           @default(0) @map("fee_portion") @db.Decimal(19, 4)
  dueDate           DateTime          @map("due_date") @db.Date
  status            InstallmentStatus @default(pending)
  paidAmount        Decimal           @default(0) @map("paid_amount") @db.Decimal(19, 4)
  paidAt            DateTime?         @map("paid_at") @db.Timestamptz(6)
  daysPastDue       Int               @default(0) @map("days_past_due")
  /// Sprint 12 G2 — auto-collection tracking. Last time the BNPL
  /// auto-collect scheduler attempted a wallet pull on this installment.
  /// Used for same-day idempotency: a re-run of the scheduler on the
  /// same UTC day skips installments where this is >= startOfToday().
  lastCollectionAttemptAt DateTime?    @map("last_collection_attempt_at") @db.Timestamptz(6)
  /// Cumulative count of failed auto-collection attempts. The scheduler
  /// stops trying once this hits `bnplConfig.collectionRetryMaxAttempts`
  /// (default 3) and hands the installment off to the overdue/recovery flow.
  collectionAttemptCount  Int          @default(0) @map("collection_attempt_count")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  transaction BnplTransaction @relation(fields: [transactionId], references: [id])

  @@unique([transactionId, installmentNumber])
  @@index([tenantId])
  @@index([transactionId])
  @@index([dueDate])
  @@index([status])
  @@map("installment_schedules")
}

enum InstallmentStatus {
  pending
  due
  paid
  overdue
  waived

  @@map("installment_status")
}

/// Settlement run paying a merchant for one or more transactions. For
/// IMMEDIATE merchants there's one settlement per transaction (created
/// at origination). For T+1 merchants the daily batch job groups all
/// approved-but-unsettled transactions into one row per merchant per day.
model MerchantSettlement {
  id               String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String                   @map("tenant_id") @db.Uuid
  merchantId       String                   @map("merchant_id") @db.Uuid
  /// Single-transaction settlements (IMMEDIATE mode) link the source
  /// transaction here; batch (T+1) settlements leave it null and use the
  /// `transactionCount` summary instead.
  currency         String                   @db.VarChar(3)
  grossAmount      Decimal                  @map("gross_amount") @db.Decimal(19, 4)
  discountFee      Decimal                  @map("discount_fee") @db.Decimal(19, 4)
  netAmount        Decimal                  @map("net_amount") @db.Decimal(19, 4)
  transactionCount Int                      @map("transaction_count")
  periodStart      DateTime                 @map("period_start") @db.Date
  periodEnd        DateTime                 @map("period_end") @db.Date
  status           MerchantSettlementStatus @default(pending)
  settledAt        DateTime?                @map("settled_at") @db.Timestamptz(6)
  walletRef        String?                  @map("wallet_ref") @db.VarChar(255)
  failureReason    String?                  @map("failure_reason") @db.Text
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  merchant     Merchant          @relation(fields: [merchantId], references: [id])
  /// FIX 5: many transactions can share one settlement (T+1 batches).
  /// IMMEDIATE settlements still have exactly one transaction in this list.
  transactions BnplTransaction[]

  @@index([tenantId])
  @@index([merchantId])
  @@index([status])
  @@index([periodEnd])
  @@map("merchant_settlements")
}

enum MerchantSettlementStatus {
  pending
  processing
  settled
  failed

  @@map("merchant_settlement_status")
}

// ─────────────────────────────────────────────────────────────────────────
// Sprint 15 (S15-1) — BNPL per-customer credit lines.
//
// The existing `Subscription.creditLimit` / `availableLimit` fields are
// retained for backwards compatibility but lack review scheduling, status
// lifecycle, and adjustment history. `BnplCreditLine` is the canonical
// home for these going forward. One credit line per (customer, BNPL
// subscription); enforced via the unique constraint.
// ─────────────────────────────────────────────────────────────────────────

enum BnplCreditLineStatus {
  active
  suspended
  closed
  /// Sprint 16 (S16-FIX-1): credit lines past `expiresAt` transition
  /// to `expired` rather than `closed` so we preserve the historical
  /// distinction between "operator/customer-initiated closure" and
  /// "lapsed without explicit action."
  expired

  @@map("bnpl_credit_line_status")
}

model BnplCreditLine {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  customerId      String               @map("customer_id") @db.Uuid
  /// `@unique` enables the one-to-one Subscription ↔ BnplCreditLine
  /// relation. Composite `@@unique([tenantId, customerId, subscriptionId])`
  /// below also enforces tenant scoping at the DB level.
  subscriptionId  String               @unique @map("subscription_id") @db.Uuid
  productId       String               @map("product_id") @db.Uuid
  /// Maximum credit extended to the customer on this subscription.
  approvedLimit   Decimal              @map("approved_limit") @db.Decimal(19, 4)
  /// Remaining headroom (decreases on purchase, increases on principal
  /// repayment). Capped at `approvedLimit` — never exceeds.
  availableLimit  Decimal              @map("available_limit") @db.Decimal(19, 4)
  currency        String               @db.VarChar(3)
  status          BnplCreditLineStatus @default(active)
  /// Sprint 16 (S16-FIX-1): when the line first transitioned to `active`.
  /// Set ONLY on first activation — re-activation after suspension does
  /// NOT overwrite. Drives regulatory "credit granted on" reporting.
  activatedAt     DateTime?            @map("activated_at") @db.Timestamptz(6)
  /// Sprint 16 (S16-FIX-1): hard deadline after which the line cannot
  /// be used. `BnplCreditLineAdjustmentService` checks this on every
  /// evaluation and transitions the line to `expired` when passed.
  expiresAt       DateTime?            @map("expires_at") @db.Timestamptz(6)
  lastReviewedAt  DateTime?            @map("last_reviewed_at") @db.Timestamptz(6)
  nextReviewAt    DateTime?            @map("next_review_at") @db.Timestamptz(6)
  suspendedAt     DateTime?            @map("suspended_at") @db.Timestamptz(6)
  suspendedReason String?              @map("suspended_reason") @db.Text
  closedAt        DateTime?            @map("closed_at") @db.Timestamptz(6)
  closedReason    String?              @map("closed_reason") @db.Text
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?            @map("deleted_at") @db.Timestamptz(6)

  customer     Customer                  @relation(fields: [customerId], references: [id])
  subscription Subscription              @relation(fields: [subscriptionId], references: [id])
  product      Product                   @relation(fields: [productId], references: [id])
  adjustments  BnplCreditLineAdjustment[]

  @@unique([tenantId, customerId, subscriptionId])
  @@index([tenantId])
  @@index([customerId])
  @@index([subscriptionId])
  /// FIX-15: every FK must have an index per CLAUDE.md — the `productId`
  /// scalar was missing a backing index, so the BnplCreditLineAdjustmentService
  /// trigger-evaluation queries that join on `product` had to seq-scan.
  @@index([productId])
  @@index([status])
  @@index([nextReviewAt])
  /// Sprint 16 (S16-FIX-1): partial-style index for the daily expiry sweep.
  /// Prisma can't model `WHERE expires_at IS NOT NULL` partials; the SQL
  /// migration creates the partial index in addition to this basic one.
  @@index([expiresAt])
  @@map("bnpl_credit_lines")
}

/// Append-only audit trail of every limit change. Created by the
/// BnplCreditLineAdjustmentService on each adjustment + by manual operator
/// actions. `triggeredBy` is the actor: `system`, `operator:<userId>`, or
/// the AdjustmentTrigger enum value (purchase_history, scheduled_review, etc).
model BnplCreditLineAdjustment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  creditLineId    String   @map("credit_line_id") @db.Uuid
  previousLimit   Decimal  @map("previous_limit") @db.Decimal(19, 4)
  newLimit        Decimal  @map("new_limit") @db.Decimal(19, 4)
  /// One of: `increase`, `decrease`, `reset`.
  adjustmentType  String   @map("adjustment_type") @db.VarChar(50)
  /// Free-form short code (e.g. `repayment_streak`, `late_payment_streak`,
  /// `score_drop`, `manual_operator`). Matched against AdjustmentTrigger.
  reasonCode      String   @map("reason_code") @db.VarChar(50)
  reasonDetail    String?  @map("reason_detail") @db.Text
  triggeredBy     String   @map("triggered_by") @db.VarChar(80)
  /// FIX-3 (Sprint 15): per-CLAUDE.md every mutation accepts an
  /// idempotencyKey. Duplicate manual adjustments with the same key
  /// return the existing record instead of double-applying. Nullable so
  /// system-triggered adjustments (which already cool down on
  /// reviewFrequencyDays) don't require one.
  idempotencyKey  String?  @map("idempotency_key") @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  creditLine BnplCreditLine @relation(fields: [creditLineId], references: [id])

  @@index([tenantId])
  @@index([creditLineId])
  /// FIX-3 + FIX-15: scoped to `idempotencyKey IS NOT NULL` via the
  /// migration partial index (Prisma doesn't model that natively; the
  /// composite unique here is correct for cross-tenant isolation, and
  /// the per-row NULL behaviour falls out of Postgres's standard
  /// "NULLs are distinct" semantics).
  @@unique([tenantId, idempotencyKey])
  @@map("bnpl_credit_line_adjustments")
}

// ─────────────────────────────────────────────────────────────────────────
// Sprint 12 — Invoice Factoring (spec: Docs/SPEC-invoice-factoring.md)
// Buyer (debtor) is modelled as a separate entity from Customer because the
// debtor is NOT a borrower in the IF flow — they're the counterparty whose
// obligation backs the seller's advance. Different lifecycle, different
// risk model, different KYC requirements.
// ─────────────────────────────────────────────────────────────────────────

model Debtor {
  id                     String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String       @map("tenant_id") @db.Uuid
  companyName            String       @map("company_name") @db.VarChar(255)
  tradingName            String?      @map("trading_name") @db.VarChar(255)
  registrationNumber     String?      @map("registration_number") @db.VarChar(100)
  /// Sprint 13B (S13B-2): SHA-256 of normalised lowercase registrationNumber.
  /// Drives debtor-payment matching now that registrationNumber is encrypted.
  registrationNumberHash String?      @map("registration_number_hash") @db.VarChar(64)
  taxId                  String?      @map("tax_id") @db.VarChar(100)
  /// Sprint 13B (S13B-2): SHA-256 of normalised lowercase taxId, for the
  /// debtor-payment matching service's lookup paths.
  taxIdHash              String?      @map("tax_id_hash") @db.VarChar(64)
  country                String       @db.VarChar(3)
  industrySector         String?      @map("industry_sector") @db.VarChar(100)
  contactEmail           String?      @map("contact_email") @db.VarChar(255)
  contactPhone           String?      @map("contact_phone") @db.VarChar(50)
  contactName            String?      @map("contact_name") @db.VarChar(255)
  address                Json?
  paymentTerms           String?      @map("payment_terms") @db.VarChar(50)
  averagePaymentDays     Int?         @map("average_payment_days")
  externalCreditRating   String?      @map("external_credit_rating") @db.VarChar(50)
  internalRiskScore      Decimal?     @map("internal_risk_score") @db.Decimal(5, 2)
  totalExposure          Decimal      @default(0) @map("total_exposure") @db.Decimal(19, 4)
  exposureLimit          Decimal?     @map("exposure_limit") @db.Decimal(19, 4)
  status                 DebtorStatus @default(active)
  verifiedAt             DateTime?    @map("verified_at") @db.Timestamptz(6)
  metadata               Json?
  createdAt              DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime?    @map("deleted_at") @db.Timestamptz(6)

  invoices Invoice[]

  /// FIX-S13B-1 (F-S13B-1): unique moves from `registrationNumber` (encrypted,
  /// non-deterministic ciphertext) to `registrationNumberHash` (deterministic
  /// SHA-256). The implicit index on the unique tuple subsumes the previous
  /// `@@index([tenantId, registrationNumberHash])`.
  @@unique([tenantId, companyName, registrationNumberHash])
  @@index([tenantId])
  @@index([status])
  @@index([industrySector])
  @@index([tenantId, taxIdHash])
  @@map("debtors")
}

enum DebtorStatus {
  active
  under_review
  suspended
  blacklisted

  @@map("debtor_status")
}

model Invoice {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String             @map("tenant_id") @db.Uuid
  sellerId           String             @map("seller_id") @db.Uuid
  debtorId           String             @map("debtor_id") @db.Uuid
  productId          String             @map("product_id") @db.Uuid
  contractId         String?            @unique @map("contract_id") @db.Uuid
  idempotencyKey     String             @map("idempotency_key") @db.VarChar(255)
  invoiceNumber      String             @map("invoice_number") @db.VarChar(100)
  issueDate          DateTime           @map("issue_date") @db.Date
  dueDate            DateTime           @map("due_date") @db.Date
  faceValue          Decimal            @map("face_value") @db.Decimal(19, 4)
  currency           String             @db.VarChar(3)
  advanceRatePercent Decimal            @map("advance_rate_percent") @db.Decimal(5, 2)
  advancedAmount     Decimal?           @map("advanced_amount") @db.Decimal(19, 4)
  reserveAmount      Decimal?           @map("reserve_amount") @db.Decimal(19, 4)
  discountFee        Decimal?           @map("discount_fee") @db.Decimal(19, 4)
  serviceFee         Decimal?           @map("service_fee") @db.Decimal(19, 4)
  netDisbursement    Decimal?           @map("net_disbursement") @db.Decimal(19, 4)
  status             InvoiceStatus      @default(submitted)
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  verifiedBy         String?            @map("verified_by") @db.Uuid
  verifiedAt         DateTime?          @map("verified_at") @db.Timestamptz(6)
  verificationNotes  String?            @map("verification_notes") @db.Text
  recourseType       RecourseType       @default(with_recourse) @map("recourse_type")
  offerExpiresAt     DateTime?          @map("offer_expires_at") @db.Timestamptz(6)
  debtorNotifiedAt   DateTime?          @map("debtor_notified_at") @db.Timestamptz(6)
  debtorPaymentRef   String?            @map("debtor_payment_ref") @db.VarChar(255)
  debtorPaidAt       DateTime?          @map("debtor_paid_at") @db.Timestamptz(6)
  amountReceived     Decimal?           @default(0) @map("amount_received") @db.Decimal(19, 4)
  reserveReleased    Decimal?           @default(0) @map("reserve_released") @db.Decimal(19, 4)
  disputeReason      String?            @map("dispute_reason") @db.Text
  documents          Json?
  metadata           Json?
  fundedAt           DateTime?          @map("funded_at") @db.Timestamptz(6)
  settledAt          DateTime?          @map("settled_at") @db.Timestamptz(6)
  defaultedAt        DateTime?          @map("defaulted_at") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  seller   Customer  @relation(fields: [sellerId], references: [id])
  debtor   Debtor    @relation(fields: [debtorId], references: [id])
  product  Product   @relation(fields: [productId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, sellerId, invoiceNumber])
  @@index([tenantId])
  @@index([sellerId])
  @@index([debtorId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

enum InvoiceStatus {
  submitted
  under_review
  verified
  offer_generated
  offer_accepted
  funded
  debtor_notified
  payment_received
  reserve_released
  settled
  disputed
  defaulted
  cancelled
  rejected

  @@map("invoice_status")
}

enum VerificationStatus {
  pending
  verified
  failed
  waived

  @@map("verification_status")
}

enum RecourseType {
  with_recourse
  without_recourse

  @@map("recourse_type")
}

// ============================================================================
// SPRINT 14 — COMMERCIAL BILLING (S14-12, S14-13)
// ============================================================================

/// Sprint 14 (S14-12) — Generated billing invoices. Two flavours today
/// (`subscription`, `usage`) and one reserved for the future revenue-share
/// commercial model. Invoice numbers are sequential per tenant per year
/// in the format `INV-{YYYY}-{NNNN}`; collision is handled by the
/// `BillingInvoiceNumberService` retry loop, and the `(tenantId,
/// invoiceNumber)` unique constraint here is the backstop.
///
/// Monetary fields are Decimal(19,4) per CLAUDE.md — never read these as
/// `number` (`Number(...)` would lose precision on amounts > 2⁵³).
model BillingInvoice {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String               @map("tenant_id") @db.Uuid
  invoiceNumber       String               @map("invoice_number") @db.VarChar(30)
  type                BillingInvoiceType
  billingPeriodStart  DateTime             @map("billing_period_start") @db.Date
  billingPeriodEnd    DateTime             @map("billing_period_end") @db.Date
  currency            String               @default("USD") @db.VarChar(3)
  subtotal            Decimal              @db.Decimal(19, 4)
  taxAmount           Decimal              @default(0) @map("tax_amount") @db.Decimal(19, 4)
  total               Decimal              @db.Decimal(19, 4)
  status              BillingInvoiceStatus @default(draft)
  issuedAt            DateTime?            @map("issued_at") @db.Timestamptz(6)
  dueDate             DateTime?            @map("due_date") @db.Date
  paidAt              DateTime?            @map("paid_at") @db.Timestamptz(6)
  notes               String?              @db.Text
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  lineItems           BillingLineItem[]
  disbursementFees    DisbursementFee[]
  tenant              Tenant               @relation(fields: [tenantId], references: [id])

  /// Per-tenant uniqueness on the invoice number. The
  /// `(tenantId, type, billingPeriodStart)` combination is *also* unique
  /// in practice — re-running the subscription job for the same month
  /// hits this and returns the existing invoice — but we enforce
  /// idempotency at the application layer (findFirst-then-return) to
  /// give a friendlier error path than a P2002.
  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([billingPeriodStart])
  @@index([tenantId, type, billingPeriodStart])
  @@map("billing_invoices")
}

/// Sprint 14 (S14-12) — Individual line items on a billing invoice.
/// Usage invoices group disbursement fees by product type into one line
/// each (description: "Micro-Loan disbursement fees (N transactions)").
/// Subscription invoices have exactly one line.
model BillingLineItem {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billingInvoiceId  String              @map("billing_invoice_id") @db.Uuid
  type              BillingLineItemType
  description       String              @db.VarChar(500)
  quantity          Int                 @default(1)
  unitPrice         Decimal             @map("unit_price") @db.Decimal(19, 4)
  amount            Decimal             @db.Decimal(19, 4)
  currency          String              @default("USD") @db.VarChar(3)
  metadata          Json?
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  billingInvoice    BillingInvoice      @relation(fields: [billingInvoiceId], references: [id], onDelete: Cascade)

  @@index([billingInvoiceId])
  @@map("billing_line_items")
}

/// Sprint 14 (S14-13) — Per-disbursement metered fee record.
///
/// Created when a `DISBURSEMENT_COMPLETED` event fires. The rate
/// calculation captures every input so the fee is fully reproducible:
///   effective_bps = (base_bps + product_modifier_bps) * volume_multiplier
///   fee_amount    = bankersRound(gross_amount * effective_bps / 10000, 4)
///   fee_amount_usd = fee_amount * exchange_rate
/// All inputs (base_bps, modifier, multiplier, rate, FX) are persisted
/// alongside the result so the SP can audit any line on a usage invoice
/// after the fact, even if rates change later.
///
/// `(tenantId, disbursementId)` is unique so re-running the listener for
/// the same DISBURSEMENT_COMPLETED event is a no-op. The listener
/// short-circuits on `findUnique` before we hit this constraint, but it's
/// the backstop for races.
///
/// `billingInvoiceId` is null until the monthly usage job links the fee
/// to its invoice (the link is what turns "metered" into "billed").
model DisbursementFee {
  id                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                 String          @map("tenant_id") @db.Uuid
  disbursementId           String          @unique @map("disbursement_id") @db.Uuid
  contractId               String          @map("contract_id") @db.Uuid
  productType              String          @map("product_type") @db.VarChar(30)
  grossAmount              Decimal         @map("gross_amount") @db.Decimal(19, 4)
  currency                 String          @db.VarChar(3)
  baseBps                  Decimal         @map("base_bps") @db.Decimal(7, 2)
  productModifierBps       Decimal         @map("product_modifier_bps") @db.Decimal(7, 2)
  effectiveBps             Decimal         @map("effective_bps") @db.Decimal(7, 2)
  volumeDiscountMultiplier Decimal         @map("volume_discount_multiplier") @db.Decimal(7, 4)
  feeRate                  Decimal         @map("fee_rate") @db.Decimal(7, 2)
  feeAmount                Decimal         @map("fee_amount") @db.Decimal(19, 4)
  feeAmountUsd             Decimal         @map("fee_amount_usd") @db.Decimal(19, 4)
  exchangeRate             Decimal?        @map("exchange_rate") @db.Decimal(12, 6)
  volumeTier               String?         @map("volume_tier") @db.VarChar(50)
  billingInvoiceId         String?         @map("billing_invoice_id") @db.Uuid
  createdAt                DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  disbursement   Disbursement   @relation(fields: [disbursementId], references: [id])
  billingInvoice BillingInvoice? @relation(fields: [billingInvoiceId], references: [id])

  @@unique([tenantId, disbursementId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([billingInvoiceId])
  @@index([tenantId, productType])
  @@map("disbursement_fees")
}
