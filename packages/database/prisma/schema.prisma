  requestedTenor   Int?              @map("requested_tenor")
  currency         String            @db.VarChar(3)
  channel          String?           @db.VarChar(50)
  status           LoanRequestStatus @default(received)
  rejectionReasons Json?             @map("rejection_reasons")
  scoringResultId  String?           @map("scoring_result_id") @db.Uuid
  approvedAmount   Decimal?          @map("approved_amount") @db.Decimal(19, 4)
  approvedTenor    Int?              @map("approved_tenor")
  offerDetails     Json?             @map("offer_details")
  offerExpiresAt   DateTime?         @map("offer_expires_at") @db.Timestamptz(6)
