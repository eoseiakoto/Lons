  sharePercentage Decimal  @map("share_percentage") @db.Decimal(5, 2)
  shareAmount     Decimal  @map("share_amount") @db.Decimal(19, 4)
  deductions      Decimal  @default(0) @db.Decimal(19, 4)
  netAmount       Decimal  @map("net_amount") @db.Decimal(19, 4)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  settlementRun SettlementRun @relation(fields: [settlementRunId], references: [id])

  @@index([tenantId])
  @@index([settlementRunId])
  @@map("settlement_lines")
}

model ReconciliationRun {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  runDate        DateTime @map("run_date") @db.Timestamptz(6)
  status         String   @db.VarChar(50)
