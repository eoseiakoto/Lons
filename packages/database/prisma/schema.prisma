/// `per_disbursement` charges a basis-point fee on every disbursement.
/// `revenue_share` charges a percentage of the SP's gross revenue (deferred
/// to a later sprint — the column exists so the model is forward-compatible).
enum BillingModel {
  per_disbursement
  revenue_share

  @@map("billing_model")
}

