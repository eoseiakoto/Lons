// ============================================================================
// TENANT SCHEMA — SETTLEMENT & RECONCILIATION (Phase 3)
// ============================================================================

enum SettlementStatus {
  calculated
  approved
  executing
  settled
  failed
}

model SettlementRun {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String           @map("tenant_id") @db.Uuid
  periodStart   DateTime         @map("period_start") @db.Date
  periodEnd     DateTime         @map("period_end") @db.Date
  status        SettlementStatus @default(calculated)
  totalRevenue  Decimal          @map("total_revenue") @db.Decimal(19, 4)
  approvedBy    String?          @map("approved_by") @db.Uuid
  approvedAt    DateTime?        @map("approved_at") @db.Timestamptz(6)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  lines         SettlementLine[]

  @@index([tenantId])
  @@index([status])
  @@map("settlement_runs")
}

model SettlementLine {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String         @map("tenant_id") @db.Uuid
  settlementRunId   String         @map("settlement_run_id") @db.Uuid
  partyType         String         @map("party_type") @db.VarChar(50)
  partyId           String         @map("party_id") @db.Uuid
  grossRevenue      Decimal        @map("gross_revenue") @db.Decimal(19, 4)
  sharePercentage   Decimal        @map("share_percentage") @db.Decimal(5, 2)
  shareAmount       Decimal        @map("share_amount") @db.Decimal(19, 4)
  deductions        Decimal        @default(0) @db.Decimal(19, 4)
  netAmount         Decimal        @map("net_amount") @db.Decimal(19, 4)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  settlementRun     SettlementRun  @relation(fields: [settlementRunId], references: [id])

  @@index([tenantId])
  @@index([settlementRunId])
  @@map("settlement_lines")
}

model ReconciliationRun {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String                    @map("tenant_id") @db.Uuid
  runDate         DateTime                  @map("run_date") @db.Timestamptz(6)
  status          String                    @db.VarChar(50)
  matchRate       Decimal?                  @map("match_rate") @db.Decimal(5, 2)
  totalTxns       Int                       @map("total_txns")
  matchedTxns     Int                       @map("matched_txns")
  exceptionCount  Int                       @map("exception_count")
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)

  exceptions      ReconciliationException[]

  @@index([tenantId])
  @@index([runDate])
  @@map("reconciliation_runs")
}

model ReconciliationException {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String             @map("tenant_id") @db.Uuid
  reconciliationRunId   String             @map("reconciliation_run_id") @db.Uuid
  contractId            String?            @map("contract_id") @db.Uuid
  txnType               String             @map("txn_type") @db.VarChar(50)
  externalRef           String?            @map("external_ref") @db.VarChar(255)
  exceptionType         String             @map("exception_type") @db.VarChar(50)
  severity              String             @db.VarChar(50)
  amount                Decimal?           @db.Decimal(19, 4)
  description           String?            @db.Text
  investigation         String?            @db.Text
  resolved              Boolean            @default(false)
  resolvedAt            DateTime?          @map("resolved_at") @db.Timestamptz(6)
  resolvedBy            String?            @map("resolved_by") @db.Uuid
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  reconciliationRun     ReconciliationRun  @relation(fields: [reconciliationRunId], references: [id])

  @@index([tenantId])
  @@index([reconciliationRunId])
  @@index([severity])
  @@index([resolved])
  @@map("reconciliation_exceptions")
}

model CollectionsAction {
