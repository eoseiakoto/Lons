  @@unique([tenantId, contractNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([productId])
  @@index([status])
  @@index([classification])
  @@index([daysPastDue])
  @@index([maturityDate])
  @@index([createdAt])
  @@map("contracts")
}

model RepaymentScheduleEntry {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String                  @map("tenant_id") @db.Uuid
  contractId        String                  @map("contract_id") @db.Uuid
  installmentNumber Int                     @map("installment_number")
  dueDate           DateTime                @map("due_date") @db.Date
  principalAmount   Decimal?                @map("principal_amount") @db.Decimal(19, 4)
  interestAmount    Decimal?                @map("interest_amount") @db.Decimal(19, 4)
  feeAmount         Decimal?                @map("fee_amount") @db.Decimal(19, 4)
  totalAmount       Decimal                 @map("total_amount") @db.Decimal(19, 4)
  paidAmount        Decimal                 @default(0) @map("paid_amount") @db.Decimal(19, 4)
  status            RepaymentScheduleStatus @default(pending)
  paidAt            DateTime?               @map("paid_at") @db.Timestamptz(6)
  /// Sprint 15 (S15-5): generic auto-deduction retry tracking. Mirrors
  /// the BNPL InstallmentSchedule pattern for Micro-Loan / Overdraft
  /// installments handled by AutoDeductionJob.
  lastDeductionAttemptAt DateTime?           @map("last_deduction_attempt_at") @db.Timestamptz(6)
  deductionAttemptCount  Int                 @default(0) @map("deduction_attempt_count")
  nextDeductionRetryAt   DateTime?           @map("next_deduction_retry_at") @db.Timestamptz(6)
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  contract Contract @relation(fields: [contractId], references: [id])

  @@unique([contractId, installmentNumber])
  @@index([tenantId])
  @@index([dueDate])
  @@index([status])
  @@index([nextDeductionRetryAt])
  @@map("repayment_schedule")
}

model Disbursement {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String             @map("tenant_id") @db.Uuid
  contractId    String             @map("contract_id") @db.Uuid
  customerId    String             @map("customer_id") @db.Uuid
  amount        Decimal            @db.Decimal(19, 4)
  currency      String             @db.VarChar(3)
  channel       String?            @db.VarChar(50)
  destination   String?            @db.VarChar(255)
  externalRef   String?            @map("external_ref") @db.VarChar(255)
  status        DisbursementStatus @default(pending)
  retryCount    Int                @default(0) @map("retry_count")
  failureReason String?            @map("failure_reason") @db.Text
  completedAt   DateTime?          @map("completed_at") @db.Timestamptz(6)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  contract Contract @relation(fields: [contractId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  // Sprint 14 (S14-13): metered per-disbursement fee record.
  disbursementFee DisbursementFee?

  @@index([tenantId])
  @@index([contractId])
  @@index([status])
  @@index([externalRef])
  @@map("disbursements")
}

model Repayment {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  contractId         String              @map("contract_id") @db.Uuid
  customerId         String              @map("customer_id") @db.Uuid
  amount             Decimal             @db.Decimal(19, 4)
  currency           String              @db.VarChar(3)
  method             RepaymentMethodType
  source             String?             @db.VarChar(50)
  externalRef        String?             @map("external_ref") @db.VarChar(255)
  allocatedPrincipal Decimal?            @map("allocated_principal") @db.Decimal(19, 4)
  allocatedInterest  Decimal?            @map("allocated_interest") @db.Decimal(19, 4)
  allocatedFees      Decimal?            @map("allocated_fees") @db.Decimal(19, 4)
  allocatedPenalties Decimal?            @map("allocated_penalties") @db.Decimal(19, 4)
  status             RepaymentStatus     @default(pending)
  failureReason      String?             @map("failure_reason") @db.Text
  receiptNumber      String?             @map("receipt_number") @db.VarChar(50)
  /// Sprint 16 fixes (FIX-3): replay key set by the GraphQL caller.
  /// A duplicate `processRepayment` mutation with the same key
  /// returns the existing row instead of creating a second repayment.
  /// Nullable so legacy / internal callers without a key still work;
  /// the partial unique index (migration) keeps NULLs from colliding.
  idempotencyKey     String?             @map("idempotency_key") @db.VarChar(255)
  completedAt        DateTime?           @map("completed_at") @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  contract Contract @relation(fields: [contractId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([contractId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("repayments")
}

model LedgerEntry {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  contractId     String          @map("contract_id") @db.Uuid
  entryType      LedgerEntryType @map("entry_type")
