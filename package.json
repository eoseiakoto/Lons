{
  "name": "lons",
  "version": "0.1.0",
  "private": true,
  "description": "Lōns — B2B2C fintech lending platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @lons/database db:migrate",
    "db:migrate:dev": "pnpm --filter @lons/database db:migrate:dev",
    "db:seed": "pnpm --filter @lons/database db:seed",
    "db:studio": "pnpm --filter @lons/database db:studio",
    "db:generate": "pnpm --filter @lons/database db:generate",
    "encrypt-pii": "tsx scripts/encrypt-existing-pii.ts",
    "audit:permissions": "pnpm --filter @lons/database exec ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"target\":\"es2022\",\"esModuleInterop\":true,\"skipLibCheck\":true}' --skip-project ../../scripts/audit-permissions.ts",
    "verify:synced": "bash scripts/verify-synced-files.sh",
    "test:regression": "jest --config tests/regression/jest.config.ts --runInBand",
    "test:staging": "jest --config tests/staging/jest.config.ts --runInBand",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "jest-junit": "^16.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
